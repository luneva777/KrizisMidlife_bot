# 🧠 КЛАВИАТУРА ДЛЯ ТЕСТА
def get_test_keyboard(q_index: int):
    return InlineKeyboardMarkup(inline_keyboard=[
        [
            InlineKeyboardButton(text="0 — совсем не про меня", callback_data=f"test_{q_index}_0"),
            InlineKeyboardButton(text="1 — иногда бывает", callback_data=f"test_{q_index}_1")
        ],
        [
            InlineKeyboardButton(text="2 — часто", callback_data=f"test_{q_index}_2"),
