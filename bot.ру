@dp.message(Command("test"))
async def cmd_test(message: types.Message):
    user_scores[message.from_user.id] = {"current": 0, "score": 0}
    await message.answer(
        "🧠 Короткий тест: проверьте своё состояние\n\n"
        "Кризис среднего возраста — это не просто плохое настроение. "
