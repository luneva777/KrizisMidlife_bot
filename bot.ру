        "жизни, тревогой о будущем и эмоциональным напряжением.\n\n"
        f"**Вопрос 1 из {len(QUESTIONS)}:**\n{QUESTIONS[0]}",
        reply_markup=get_test_keyboard(0)
    )

# 🎯 ОБРАБОТКА НАЖАТИЙ НА КНОПКИ
@dp.callback_query()
async def handle_test(callback: CallbackQuery):
    data = callback.data
    user_id = callback.from_user.id

    if not data.startswith("test_"):
        await callback.answer()
        return

    parts = data.split("_")
    if len(parts) != 3:
        await callback.answer("Ошибка")
        return

    try:
        q_index = int(parts[1])
        value = int(parts[2])
    except ValueError:
        await callback.answer("Ошибка")
        return

    if user_id not in user_scores:
        user_scores[user_id] = {"current": 0, "score": 0}

    # Сохраняем балл
    if value in [0, 1, 2, 3]:
        user_scores[user_id]["score"] += value

    next_q = q_index + 1

    if next_q >= len(QUESTIONS):
        # Тест завершён
        score = user_scores[user_id]["score"]

        if score <= 6:
            result = (
                "0–6 баллов — вы в порядке. Кризис вас не касается. "
                "Если что-то беспокоит — возможно, это просто усталость. "
                "Отдохните или начните с /calm."
            )
        elif score <= 12:
            result = (
                "7–12 баллов — вы на подступах к переоценке. Это нормально: "
                "многие в этом возрасте начинают задавать себе вопросы. "
                "Обратите внимание на то, что вас тревожит. Начните с /talk."
            )
        elif score <= 18:
            result = (
                "13–18 баллов — вы в активной фазе кризиса среднего возраста. "
                "Это не страшно, это этап. Но если состояние длится больше нескольких месяцев "
                "или мешает жить — подумайте о разговоре с психологом."
            )
        else:
            result = (
                "19–21 балл — состояние выраженное. Это может быть не просто кризис, "
                "а депрессия или тревожное расстройство. Рекомендуем обратиться к специалисту. "
                "Это не слабость — это забота о себе."
            )

        await callback.message.edit_text(
            f"✅ Тест завершён!\n\n"
            f"Ваш результат: {score} из {len(QUESTIONS) * 3}\n\n"
            f"{result}"
        )
        await callback.answer()
        return

    # Следующий вопрос
    await callback.message.edit_text(
        f"🧠 Короткий тест: проверьте своё состояние\n\n"
        f"**Вопрос {next_q + 1} из {len(QUESTIONS)}:**\n{QUESTIONS[next_q]}",
        reply_markup=get_test_keyboard(next_q)
    )
    await callback.answer()

